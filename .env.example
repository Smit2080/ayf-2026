# Example environment variables for local development and deployment reference.
# Copy this to .env.local for local development.
# Configure these variables in your hosting provider (e.g. Vercel, Netlify) for production.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Optional: enables admin PATCH endpoints to bypass RLS
# Find it in Supabase Dashboard > Settings > API > service_role key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
